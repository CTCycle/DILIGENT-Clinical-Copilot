{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DILIGENT Desktop",
  "version": "1.0.0",
  "identifier": "com.diligent.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DILIGENT Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../app/server/pyproject.toml": "r/pyproject.toml",
      "../../server": "r/server",
      "../../scripts": "r/scripts",
      "../../../settings": "r/settings",
      "../dist": "r/client/dist",
      "../../resources/models": "r/resources/models",
      "../../resources/sources": "r/resources/sources",
      "../../server/uv.lock": "r/runtimes/uv.lock",
      "../../../runtimes/python": "r/runtimes/python",
      "../../../runtimes/uv": "r/runtimes/uv",
      "../../../runtimes/nodejs": "r/runtimes/nodejs"
    }
  }
}

