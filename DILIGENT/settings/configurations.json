{  
  "jobs": {
    "polling_interval": 1
  },
  "database": {
    "embedded_database": true,
    "engine": "postgres",
    "host": "localhost",
    "port": 5432,
    "database_name": "DILIGENT",
    "username": "postgres",
    "password": "",
    "ssl": false,
    "ssl_ca": null,
    "connect_timeout": 30,
    "insert_batch_size": 1000,
    "insert_commit_interval": 5,
    "select_page_size": 2000
  },    
  "rag": {
    "vector_collection_name": "documents",
    "chunk_size": 1024,
    "chunk_overlap": 128,
    "embedding_batch_size": 64,
    "top_k_documents": 6,
    "embedding_backend": "ollama",
    "ollama_embedding_model": "nomic-embed-text:latest",
    "hf_embedding_model": "",
    "vector_index_metric": "cosine",
    "vector_index_type": "IVF_FLAT",
    "reset_vector_collection": true,
    "cloud_embedding_model": "",
    "use_cloud_embeddings": false,
    "vector_stream_batch_size": 1024,
    "embedding_max_workers": 4
  },
  "external_data": {
    "default_llm_timeout": 3600.0,
    "parser_llm_timeout": 3600.0,
    "disease_llm_timeout": 3600.0,
    "clinical_llm_timeout": 3600.0,
    "livertox_llm_timeout": 3600.0,
    "ollama_server_start_timeout": 15.0,
    "livertox_archive": "livertox_NBK547852.tar.gz",
    "livertox_yield_interval": 25,
    "livertox_skip_deterministic_ratio": 0.8,
    "livertox_monograph_max_workers": 4,
    "max_excerpt_length": 8000,
    "rxnav_request_timeout": 12.0,
    "rxnav_max_concurrency": 10
  },
  "ingestion": {
    "drug_name_min_length": 3,
    "drug_name_max_length": 200,
    "drug_name_max_tokens": 8
  },
  "drugs_matcher": {
    "direct_confidence": 1.0,
    "master_confidence": 0.92,
    "synonym_confidence": 0.9,
    "partial_confidence": 0.86,
    "fuzzy_confidence": 0.84,
    "fuzzy_threshold": 0.85,
    "fuzzy_early_exit_ratio": 0.95,
    "token_max_frequency": 3,
    "token_min_length": 4,
    "normalization_cache_limit": 10000,
    "variant_cache_limit": 10000,
    "min_confidence": 0.4,
    "catalog_excluded_term_suffixes": [
      "PCK"
    ],
    "catalog_token_ratio_threshold": 0.93,
    "catalog_overall_ratio_threshold": 0.93,
    "match_cache_limit": 5000,
    "alias_cache_limit": 2000,
    "catalog_index_limit": 75000,
    "catalog_candidate_limit": 750
  }
}  


