FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
UI_HOST=0.0.0.0
UI_PORT=7861
VITE_API_BASE_URL=/api
RELOAD=false

DB_EMBEDDED=false
DB_ENGINE=postgres
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_NAME=diligent
DB_USER=diligent_user
DB_PASSWORD=change-me
DB_SSL=true
DB_SSL_CA=/run/secrets/postgres-ca.crt
DB_CONNECT_TIMEOUT=10
DB_INSERT_BATCH_SIZE=1000

OPTIONAL_DEPENDENCIES=false
MPLBACKEND=Agg
KERAS_BACKEND=tensorflow

# Access keys are managed in-app via /model-config -> provider key modal.
# Must be a Fernet key (urlsafe base64-encoded 32-byte key).
ACCESS_KEY_ENCRYPTION_KEY=
