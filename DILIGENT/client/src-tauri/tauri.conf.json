{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DILIGENT Desktop",
  "version": "1.0.0",
  "identifier": "com.diligent.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DILIGENT Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "r/pyproject.toml": "pyproject.toml",
      "r/uv.lock": "uv.lock",
      "r/common": "DILIGENT/common",
      "r/server": "DILIGENT/server",
      "r/scripts": "DILIGENT/scripts",
      "r/settings": "DILIGENT/settings",
      "r/client/dist": "DILIGENT/client/dist",
      "r/resources/models": "DILIGENT/resources/models",
      "r/resources/sources": "DILIGENT/resources/sources",
      "r/resources/runtimes/python": "DILIGENT/resources/runtimes/python",
      "r/resources/runtimes/uv": "DILIGENT/resources/runtimes/uv"
    }
  }
}
